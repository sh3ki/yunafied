# Backend server port
PORT=4000

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:replace_me@ep-your-host/neondb?sslmode=require&channel_binding=require

# JWT signing secret for auth tokens
JWT_SECRET=replace_with_a_long_random_secret

# Optional upload directory for assignment files
UPLOAD_DIR=./uploads

# Cloudinary credentials (profile image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq API key for YUNA AI assistant
GROQ_API_KEY=your_groq_api_key
